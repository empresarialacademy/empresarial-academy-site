# ===== Payload CMS / Banco =====
PAYLOAD_SECRET=troque-por-um-segredo-forte-e-unico
# Local (dev): SQLite. Produção: trocar para a connection string do Postgres.
DATABASE_URI=file:./empresarial-academy.db

# ===== Envio de e-mail dos formulários =====
# Para onde os leads (contato, newsletter, pop-up) serão enviados:
LEADS_TO_EMAIL=contato@empresarialacademy.com
# Remetente exibido (precisa ser autorizado pelo provedor escolhido):
LEADS_FROM_EMAIL=Empresarial Academy <contato@empresarialacademy.com>

# --- Opção A: Resend (https://resend.com) ---
# Crie uma API key e verifique o domínio empresarialacademy.com no painel da Resend.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- Opção B: SMTP (ex.: e-mail Hostinger contato@empresarialacademy.com) ---
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=contato@empresarialacademy.com
# SMTP_PASS=sua-senha-do-email

# Se nada acima estiver configurado, os leads são apenas registrados no log do servidor.

# ===== Instagram (Behold) =====
# URL do feed JSON do Behold (ex.: https://feeds.behold.so/XXXXXXXX).
# Sem ela, a seção do Instagram exibe apenas o botão "Seguir".
# BEHOLD_FEED_URL=https://feeds.behold.so/XXXXXXXX
